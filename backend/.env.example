# AI Intelligence Hub Configuration
# Copy this to .env and fill in your values

# Server
PORT=3001
NODE_ENV=development

# Anthropic API (required for LLM analysis features)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Feed refresh interval in minutes (default: 30)
FEED_REFRESH_INTERVAL=30

# Relevance scoring context - customize to your role
RELEVANCE_CONTEXT="Senior technology executive at a Global Systemically Important Bank. Focus areas: agentic AI architecture, enterprise AI platforms, AI governance and risk management, quantum computing applications in banking, verified banking DSL, EU AI Act compliance, sovereign AI strategy, GPU infrastructure economics."
